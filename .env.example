# =============================================================================
# Rayls Hackathon Starter — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Run: cp .env.example .env

# -- Network ------------------------------------------------------------------
# Privacy Ledger RPC URL (provided by hackathon organizers)
PRIVACY_LEDGER_RPC_URL=http://localhost:8545

# DeploymentProxyRegistry address on the privacy ledger (provided by organizers)
DEPLOYMENT_PROXY_REGISTRY=0x

# -- Keys ---------------------------------------------------------------------
# Your deployer wallet private key (owns the token contract, can mint)
# Generate one with: cast wallet new
DEPLOYER_PRIVATE_KEY=0x

# Private key of your registered private-chain address (from onboarding response)
# Used to sign teleportToPublicChain transactions
REGISTERED_PRIVATE_KEY=0x

# -- Token Deployment ---------------------------------------------------------
TOKEN_NAME="Hackathon Token"
TOKEN_SYMBOL="HACK"

# -- After Deployment (fill these in after running Deploy.s.sol) ---------------
TOKEN_ADDRESS=0x

# -- Minting -------------------------------------------------------------------
# Recipient = your private chain address (from onboarding response)
MINT_RECIPIENT=0x
MINT_AMOUNT=1000

# -- Transfer to Public Chain --------------------------------------------------
# Destination = your public chain address (from onboarding response)
TRANSFER_TO=0x
TRANSFER_AMOUNT=100
# Public chain ID (provided by hackathon organizers)
PUBLIC_CHAIN_ID=7331

# -- NFT Deployment (optional — for ERC721 challenge track) -------------------
NFT_TOKEN_URI=https://example.com/metadata
NFT_NAME="Hackathon NFT"
NFT_SYMBOL="HNFT"
NFT_ADDRESS=0x
NFT_MINT_TOKEN_ID=1
NFT_TRANSFER_TOKEN_ID=0

# -- ERC1155 Deployment (optional — for multi-token projects) -----------------
MULTI_TOKEN_URI=https://example.com/multi
MULTI_TOKEN_NAME="Hackathon Multi Token"
MULTI_TOKEN_ADDRESS=0x
MULTI_TOKEN_MINT_ID=1
MULTI_TOKEN_MINT_AMOUNT=500
MULTI_TOKEN_TRANSFER_ID=1
MULTI_TOKEN_TRANSFER_AMOUNT=100

# -- Public Chain (for balance checks) ----------------------------------------
# Public Chain RPC URL (provided by hackathon organizers)
PUBLIC_CHAIN_RPC_URL=http://localhost:8845

# -- Backend API ---------------------------------------------------------------
BACKEND_URL=http://localhost:8080
USER_AUTH_KEY=
OPERATOR_AUTH_KEY=
